{
  "name": "carbon-react-starter",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@11.18.0",
  "type": "module",
  "scripts": {
    "dev": "node src/server",
    "build": "cross-env NODE_ENV=production npm run build:client && npm run build:server",
    "build:client": "cross-env NODE_ENV=production vite build --ssrManifest .vite/ssr-manifest.json  --outDir dist/client",
    "build:server": "cross-env NODE_ENV=production vite build --ssr src/entry-server.jsx --outDir dist/server",
    "lighthouse": "lhci collect",
    "lint": "npm run lint:es && npm run lint:style && npm run lint:format && npm run lint:spell",
    "lint-fix": "npm run lint:es -- --fix && npm run lint:style -- --fix && npm run lint:format",
    "lint:es": "eslint . --report-unused-disable-directives --max-warnings 0 --cache --cache-location \"node_modules/.cache/eslint/\"",
    "lint:style": "stylelint \"./**/*.scss\" --cache --cache-location \"node_modules/.cache/stylelint/\"",
    "lint:format": "prettier . --write --ignore-unknown --no-error-on-unmatched-pattern --log-level warn --cache --cache-location \"node_modules/.cache/prettier/\"",
    "lint:spell": "cspell lint --quiet \"**\"",
    "preview:prod": "cross-env NODE_ENV=production node src/server.js",
    "preview": "cross-env NODE_ENV=local node src/server.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "prepare": "husky",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "@carbon-labs/react-theme-settings": "^0.30.0",
    "@carbon/ibm-products": "^2.74.0",
    "@carbon/react": "^1.73.0",
    "@ibm/plex": "^6.4.1",
    "@lhci/cli": "^0.15.0",
    "classnames": "^2.5.1",
    "compression": "^1.7.5",
    "express": "^5.0.1",
    "i18next": "^26.0.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-fs-backend": "^2.6.0",
    "i18next-http-middleware": "^3.8.1",
    "i18next-resources-to-backend": "^1.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.0",
    "react-is": "^19.0.0",
    "react-router": "^8.0.1",
    "sirv": "^3.0.0"
  },
  "devDependencies": {
    "@cspell/dict-de-de": "^4.1.2",
    "@double-great/stylelint-a11y": "^3.0.4",
    "@eslint/js": "^9.21.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "baseline-browser-mapping": "^2.9.12",
    "conventional-changelog-conventionalcommits": "^10.2.0",
    "cross-env": "^10.0.0",
    "cspell": "^10.0.0",
    "detect-port": "^2.1.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^17.0.0",
    "msw": "^2.7.3",
    "prettier": "^3.5.3",
    "sass-embedded": "^1.85.1",
    "semantic-release": "^25.0.5",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-plugin-carbon-tokens": "^5.0.0",
    "stylelint-use-logical": "^2.1.3",
    "vite": "^8.0.0",
    "vite-plugin-i18next-loader": "^4.0.0",
    "vitest": "^4.0.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,scss,css,html,yml,yaml}": [
      "node scripts/check-copyright.js --fix",
      "git add",
      "npm run lint"
    ]
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "basic-ftp": "^6.0.1",
    "get-uri": "^8.0.0",
    "pac-proxy-agent": "^9.0.1",
    "proxy-agent": "^8.0.1"
  }
}
